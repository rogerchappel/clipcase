{
  "name": "clipcase",
  "version": "0.1.0",
  "description": "Local-first clipboard-to-casefile CLI for deterministic Markdown evidence bundles.",
  "type": "module",
  "bin": {
    "clipcase": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE",
    "docs",
    "examples",
    "fixtures",
    "scripts/smoke.sh",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/**/*.test.js",
    "pretest": "npm run build",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "clipboard",
    "markdown",
    "casefile",
    "local-first",
    "agents"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerchappel/clipcase"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/clipcase/issues"
  },
  "homepage": "https://github.com/rogerchappel/clipcase#readme"
}
